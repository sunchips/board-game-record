{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Hibachi — Base",
  "properties": {
    "players": {
      "items": {
        "properties": {
          "identity": {
            "enum": ["black", "blue", "green", "red"]
          },
          "end_state": {
            "propertyNames": {
              "enum": [
                "recipes_completed"
              ]
            },
            "properties": {
              "recipes_completed": { "type": "integer", "minimum": 0, "maximum": 3 }
            }
          }
        }
      }
    }
  }
}
