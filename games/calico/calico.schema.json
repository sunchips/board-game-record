{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Calico — Base",
  "x-score-formula": {
    "cats_vp": 1,
    "buttons_vp": 1,
    "design_goal_vp": 1
  },
  "properties": {
    "players": {
      "items": {
        "properties": {
          "end_state": {
            "propertyNames": {
              "enum": [
                "cats_vp",
                "buttons_vp",
                "design_goal_vp"
              ]
            },
            "properties": {
              "cats_vp": { "type": "integer", "minimum": 0 },
              "buttons_vp": { "type": "integer", "minimum": 0 },
              "design_goal_vp": { "type": "integer", "minimum": 0 }
            }
          }
        }
      }
    }
  }
}
