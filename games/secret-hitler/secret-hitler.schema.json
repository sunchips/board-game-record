{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Secret Hitler — Base",
  "properties": {
    "players": {
      "items": {
        "properties": {
          "identity": {
            "enum": ["liberal", "fascist", "hitler"]
          },
          "end_state": {
            "propertyNames": {
              "enum": [
                "policies_liberal",
                "policies_fascist",
                "hitler_chancellor_win",
                "hitler_assassinated"
              ]
            },
            "properties": {
              "policies_liberal": { "type": "integer", "minimum": 0, "maximum": 5 },
              "policies_fascist": { "type": "integer", "minimum": 0, "maximum": 6 },
              "hitler_chancellor_win": { "type": "boolean" },
              "hitler_assassinated": { "type": "boolean" }
            }
          }
        }
      }
    }
  }
}
