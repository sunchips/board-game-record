{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Bunny Kingdom — Base",
  "properties": {
    "players": {
      "items": {
        "properties": {
          "identity": {
            "enum": ["red", "blue", "yellow", "green"]
          },
          "end_state": {
            "propertyNames": {
              "enum": [
                "vp",
                "fiefs",
                "cities",
                "towers",
                "fief_vp",
                "parchment_vp",
                "golden_parchments"
              ]
            },
            "properties": {
              "vp": { "type": "integer", "minimum": 0 },
              "fiefs": { "type": "integer", "minimum": 0 },
              "cities": { "type": "integer", "minimum": 0 },
              "towers": { "type": "integer", "minimum": 0 },
              "fief_vp": { "type": "integer", "minimum": 0 },
              "parchment_vp": { "type": "integer", "minimum": 0 },
              "golden_parchments": { "type": "integer", "minimum": 0 }
            }
          }
        }
      }
    }
  }
}
