{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "King of New York — Base",
  "properties": {
    "players": {
      "items": {
        "properties": {
          "identity": {
            "enum": [
              "captain-fish",
              "drakonis",
              "kong",
              "meka-dragon",
              "sheriff",
              "the-king"
            ]
          },
          "end_state": {
            "propertyNames": {
              "enum": [
                "vp",
                "hearts",
                "energy",
                "power_cards",
                "superstar",
                "statue_of_liberty"
              ]
            },
            "properties": {
              "vp": { "type": "integer", "minimum": 0, "maximum": 20 },
              "hearts": { "type": "integer", "minimum": 0, "maximum": 10 },
              "energy": { "type": "integer", "minimum": 0 },
              "power_cards": { "type": "integer", "minimum": 0 },
              "superstar": { "type": "boolean" },
              "statue_of_liberty": { "type": "boolean" }
            }
          }
        }
      }
    }
  }
}
