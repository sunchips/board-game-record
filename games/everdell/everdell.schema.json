{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Everdell — Base",
  "properties": {
    "players": {
      "items": {
        "properties": {
          "end_state": {
            "propertyNames": {
              "enum": [
                "vp",
                "base_vp",
                "point_tokens",
                "event_vp",
                "journey_vp",
                "prosperity_vp",
                "constructions",
                "critters"
              ]
            },
            "properties": {
              "vp": { "type": "integer", "minimum": 0 },
              "base_vp": { "type": "integer", "minimum": 0 },
              "point_tokens": { "type": "integer", "minimum": 0 },
              "event_vp": { "type": "integer", "minimum": 0 },
              "journey_vp": { "type": "integer", "minimum": 0 },
              "prosperity_vp": { "type": "integer", "minimum": 0 },
              "constructions": { "type": "integer", "minimum": 0, "maximum": 15 },
              "critters": { "type": "integer", "minimum": 0, "maximum": 15 }
            }
          }
        }
      }
    }
  }
}
